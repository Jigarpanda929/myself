{
  "entities": {
    "Message": {
      "title": "Contact Message",
      "description": "Messages sent from the portfolio contact form",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the sender"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the sender"
        },
        "message": {
          "type": "string",
          "description": "The inquiry message content"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent"
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of all contact form submissions"
    }
  }
}
